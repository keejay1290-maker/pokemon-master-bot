# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pokemon_master

# Redis
REDIS_URL=redis://localhost:6379

# API Keys
GROQ_API_KEY=your_groq_api_key_here
POKEMON_TCG_API_KEY=your_pokemon_tcg_api_key_here

# Dashboard
DASHBOARD_PORT=3001
DASHBOARD_SECRET=your_super_secret_session_key_here
DASHBOARD_URL=http://localhost:3001
DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback
# Railway deployments may omit the two URL values above; the bot derives them
# from Railway's RAILWAY_PUBLIC_DOMAIN environment variable.

# Bot Settings
NODE_ENV=development
LOG_LEVEL=info
BOT_PREFIX=/

# Spawn Settings
SPAWN_RATE=5
SPAWN_COOLDOWN=30

# Economy Defaults
DAILY_REWARD=500
WEEKLY_REWARD=2500
MONTHLY_REWARD=10000
WORK_COOLDOWN=3600
FISH_COOLDOWN=1800
HUNT_COOLDOWN=3600

# Battle Settings
BATTLE_TIMEOUT=300

# Groq Model
GROQ_MODEL=llama-3.1-70b-versatile
