{
  "name": "pokemon-master-bot",
  "version": "1.0.0",
  "description": "A production-ready Pokemon Discord bot with economy, battles, cards, and AI features",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx src/database/seed.ts",
    "db:studio": "prisma studio",
    "dashboard": "tsx src/dashboard/server.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "@discordjs/builders": "^1.7.0",
    "@discordjs/rest": "^2.2.0",
    "discord-api-types": "^0.37.71",
    "@prisma/client": "^5.8.0",
    "redis": "^4.6.12",
    "axios": "^1.6.5",
    "groq-sdk": "^0.3.2",
    "sharp": "^0.33.2",
    "canvas": "^2.11.2",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.1",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "zod": "^3.22.4",
    "date-fns": "^3.3.1",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "p-limit": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "tsx": "^4.7.0",
    "prisma": "^5.8.0",
    "@types/node": "^20.11.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/passport": "^1.0.16",
    "@types/passport-discord": "^0.1.9",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/lodash": "^4.14.202",
    "@types/uuid": "^9.0.7",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
